# Streamlit Community Cloud Secrets Template
# Datei lokal als .streamlit/secrets.toml anlegen (niemals committen!)
# Werte in der Cloud unter: App Settings -> Secrets eintragen.

POSTGRES_USER = "your_postgres_user"
POSTGRES_PASSWORD = "your_super_secret_password"
POSTGRES_HOST = "your-postgres-host.provider.com"
POSTGRES_PORT = "5432"
POSTGRES_DB = "your_database_name"
